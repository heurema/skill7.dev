---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Auth Callback"
  description="OIDC callback for the Sift browser client on skill7.dev."
>
  <div class="mx-auto max-w-3xl py-16">
    <div id="auth-callback-shell" class="card">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">Sift auth</p>
      <h1 class="mt-3 font-heading text-4xl font-bold tracking-tight text-dark-hi">Completing sign-in</h1>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-dark-lo">
        We are exchanging the authorization code for a browser session.
      </p>
    </div>
  </div>

  <script>
    import {
      clearAuthRequest,
      exchangeCodeForSession,
      getAuthRequest,
      normalizeReturnTo,
      storeSession,
    } from "../../lib/auth";

    const shell = document.getElementById("auth-callback-shell");

    function getErrorMessage(reason: unknown): string {
      if (reason instanceof Error) {
        return reason.message;
      }
      return String(reason);
    }

    async function run(): Promise<void> {
      const params = new URLSearchParams(window.location.search);
      const code = params.get("code");
      const state = params.get("state");
      const error = params.get("error");
      const errorDescription = params.get("error_description");

      if (error) {
        throw new Error(errorDescription ?? error);
      }

      if (!code || !state) {
        throw new Error("missing authorization response");
      }

      const request = getAuthRequest();
      if (!request) {
        throw new Error("missing PKCE request context");
      }

      if (request.state !== state) {
        clearAuthRequest();
        throw new Error("state mismatch");
      }

      const session = await exchangeCodeForSession(code, request.codeVerifier);
      const returnTo = normalizeReturnTo(request.returnTo);
      storeSession(session);
      clearAuthRequest();
      window.location.replace(returnTo);
    }

    run().catch((reason) => {
      clearAuthRequest();

      if (!shell) return;
      shell.innerHTML = `
        <p class="text-xs font-mono uppercase tracking-widest text-err">Auth callback failed</p>
        <h1 class="mt-3 font-heading text-4xl font-bold tracking-tight text-dark-hi">Could not finish sign-in</h1>
        <p id="auth-callback-error" class="mt-4 max-w-2xl text-sm leading-relaxed text-dark-lo"></p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a href="/auth/login?return_to=%2Fsift%2Fapp" class="btn-primary justify-center sm:w-auto">Try again</a>
          <a href="/sift" class="btn-secondary justify-center sm:w-auto">Back to Sift</a>
        </div>
      `;

      const errorDetails = shell.querySelector<HTMLParagraphElement>("#auth-callback-error");
      if (errorDetails) {
        errorDetails.textContent = getErrorMessage(reason);
      }
    });
  </script>
</Base>
