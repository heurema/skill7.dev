---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Sign In"
  description="Start the hosted Sift auth flow on skill7.dev. This uses the public Zitadel browser client and redirects back to /auth/callback."
>
  <div class="mx-auto max-w-3xl py-16">
    <div id="auth-login-shell" class="card">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">Sift auth</p>
      <h1 class="mt-3 font-heading text-4xl font-bold tracking-tight text-dark-hi">Redirecting to sign-in</h1>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-dark-lo">
        We are starting the hosted auth flow for Sift. If redirect does not happen automatically, use the button below.
      </p>
      <div class="mt-6">
        <a id="auth-login-link" href="/sift" class="btn-primary">Continue</a>
      </div>
    </div>
  </div>

  <script>
    import { beginSiftLogin, normalizeReturnTo } from "../../lib/auth";

    const shell = document.getElementById("auth-login-shell");
    const link = document.getElementById("auth-login-link");
    const params = new URLSearchParams(window.location.search);
    const returnTo = normalizeReturnTo(params.get("return_to") ?? "/sift/app");

    beginSiftLogin(returnTo)
      .then((url) => {
        if (link instanceof HTMLAnchorElement) {
          link.href = url;
        }
        window.location.replace(url);
      })
      .catch((error) => {
        if (!shell) return;
        shell.innerHTML = `
          <p class="text-xs font-mono uppercase tracking-widest text-err">Auth setup failed</p>
          <h1 class="mt-3 font-heading text-4xl font-bold tracking-tight text-dark-hi">Could not start Sift sign-in</h1>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-dark-lo">${String(error)}</p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a href="/sift" class="btn-secondary justify-center sm:w-auto">Back to Sift</a>
            <a href="/" class="btn-ghost justify-center sm:w-auto">Back home</a>
          </div>
        `;
      });
  </script>
</Base>
