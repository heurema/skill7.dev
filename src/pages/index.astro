---
import Base from "../layouts/Base.astro";
import CopyButton from "../components/CopyButton.astro";
---

<Base
  title="Home"
  description="skill7 — cross-CLI plugin distribution for AI agents. Install plugins for Claude Code, Codex CLI, and Gemini CLI from one registry."
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 bg-dots opacity-40 pointer-events-none" />

    <div class="relative mx-auto max-w-3xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-acid/40 bg-acid-muted px-3 py-1">
        <span class="h-1.5 w-1.5 rounded-full bg-acid"></span>
        <span class="text-xs font-mono font-medium text-acid">open-source plugin registry</span>
      </div>

      <h1 class="mt-8 font-heading font-bold tracking-tight text-dark-hi">
        skill7
      </h1>
      <p class="mt-4 text-2xl sm:text-3xl font-heading font-medium text-dark-lo tracking-tight">
        One CLI installs plugins for all your AI tools
      </p>

      <p class="mt-6 text-lg leading-relaxed text-dark-lo max-w-xl mx-auto">
        Claude Code, Codex CLI, and Gemini CLI — auto-detected, one command.
      </p>

      <!-- Primary CTA: install command -->
      <div class="mt-10 mx-auto max-w-md">
        <CopyButton text="skill7 install signum" />
      </div>

      <!-- Secondary CTA -->
      <div class="mt-6">
        <a href="/marketplace" class="text-acid hover:text-acid-glow transition-colors font-medium text-sm">
          Browse plugins →
        </a>
      </div>

      <!-- Works with row -->
      <div class="mt-12 flex items-center justify-center gap-6 text-xs font-mono text-dark-dim">
        <span>Claude Code</span>
        <span class="text-dark-border">·</span>
        <span>Codex CLI</span>
        <span class="text-dark-border">·</span>
        <span>Gemini CLI</span>
      </div>
    </div>
  </section>

  <!-- For users / For developers -->
  <section class="border-t border-dark-line py-16">
    <div class="mx-auto max-w-6xl grid gap-6 sm:grid-cols-2">
      <div class="card">
        <p class="text-xs font-mono font-semibold uppercase tracking-widest text-acid">For users</p>
        <h2 class="mt-3 font-heading text-xl font-semibold text-dark-hi">Install plugins</h2>
        <p class="mt-3 text-sm leading-relaxed text-dark-lo">
          One command installs a plugin for all detected AI CLIs. skill7 auto-detects Claude Code, Codex CLI, and Gemini CLI.
        </p>
        <div class="mt-5 space-y-2">
          <CopyButton text="skill7 install herald" />
          <CopyButton text="skill7 install signum" />
        </div>
        <a href="/marketplace" class="btn-secondary mt-5 w-full justify-center">Browse registry</a>
      </div>

      <div class="card">
        <p class="text-xs font-mono font-semibold uppercase tracking-widest text-cyan">For developers</p>
        <h2 class="mt-3 font-heading text-xl font-semibold text-dark-hi">Publish plugins</h2>
        <p class="mt-3 text-sm leading-relaxed text-dark-lo">
          Scaffold a plugin, test locally, then publish to the registry. Supports all three AI CLIs from a single plugin manifest.
        </p>
        <div class="mt-5 space-y-2">
          <CopyButton text="skill7 init my-plugin" />
          <CopyButton text="skill7 publish" />
        </div>
        <a href="/getting-started" class="btn-secondary mt-5 w-full justify-center">Get started</a>
      </div>
    </div>
  </section>
</Base>
