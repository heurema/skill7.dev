---
import Base from "../layouts/Base.astro";
import PluginCard from "../components/PluginCard.astro";
import CopyButton from "../components/CopyButton.astro";
import GitHubIcon from "../components/icons/GitHubIcon.astro";
import { getCategories, getAllPlugins } from "../lib/data";

const categories = getCategories();
const allPlugins = getAllPlugins();
const totalPlugins = allPlugins.length;
---

<Base
  title="Plugin Registry"
  description="Browse cross-CLI plugins for Claude Code, Codex CLI, and Gemini CLI. Install any plugin with skill7 install."
>
  <section class="relative overflow-hidden py-24 sm:py-28 text-center">
    <div class="absolute inset-0 bg-dots opacity-40 pointer-events-none" />

    <div class="relative">
      <div class="inline-flex cursor-default items-center gap-2 rounded-full border border-acid/50 bg-acid-muted px-3 py-1">
        <span class="h-1.5 w-1.5 rounded-full bg-acid animate-pulse"></span>
        <span class="text-xs font-mono font-medium text-acid">skill7 registry</span>
      </div>

      <h1 class="mt-8 font-heading font-bold tracking-tight text-dark-hi">
        Plugin Registry
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-dark-lo">
        Open-source plugins for Claude Code, Codex CLI, and Gemini CLI.
        One command installs for all detected CLIs.
      </p>

      <p class="mt-5 text-sm font-mono text-dark-lo">
        <span class="whitespace-nowrap">{totalPlugins} plugins</span>
        <span class="whitespace-nowrap">&nbsp;·&nbsp; {categories.length} categories</span>
        <span class="whitespace-nowrap">&nbsp;·&nbsp; all open source</span>
      </p>

      <div class="mx-auto mt-10 max-w-md">
        <CopyButton text="skill7 install signum" />
      </div>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/getting-started" class="btn-primary w-full justify-center sm:w-auto">Getting Started</a>
        <a
          href="https://github.com/heurema/emporium"
          class="btn-ghost w-full justify-center sm:w-auto"
          target="_blank"
          rel="noopener"
        >
          <GitHubIcon />
          Registry on GitHub
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-dark-line py-16" id="packs">
    <div class="mb-12 text-center">
      <h2 class="font-heading text-3xl font-bold tracking-tight text-dark-hi">Start in 2 Minutes</h2>
      <p class="mt-3 text-lg text-dark-lo">
        Choose a pack. All plugins install with a single <code class="bg-dark-code px-1.5 py-0.5 rounded text-sm text-dark-hi">skill7 install</code> command.
      </p>
    </div>

    <div class="mx-auto grid max-w-3xl gap-6 lg:grid-cols-2">
      <div class="relative flex flex-col gap-5 rounded-xl p-6 border-gradient-acid shadow-glow-sm">
        <div class="absolute -top-3 left-6">
          <span class="badge border-0 bg-acid px-3 py-1 text-xs font-semibold tracking-wide text-dark-bg">
            Recommended
          </span>
        </div>

        <div>
          <div class="mb-1 flex items-center gap-2">
            <span class="text-xs font-mono font-semibold uppercase tracking-widest text-acid">Starter Pack</span>
          </div>
          <p class="text-sm leading-relaxed text-dark-lo">Zero external dependencies. Instant value.</p>
        </div>

        <ul class="flex flex-col gap-2">
          <li class="flex flex-col gap-0.5">
            <span class="font-mono text-sm font-semibold text-dark-hi">herald</span>
            <span class="text-xs text-dark-lo">News intelligence with story clustering — zero API keys, fully local.</span>
          </li>
          <li class="flex flex-col gap-0.5">
            <span class="font-mono text-sm font-semibold text-dark-hi">anvil</span>
            <span class="text-xs text-dark-lo">Plugin dev/test toolkit — scaffold, validate, test, review.</span>
          </li>
          <li class="flex flex-col gap-0.5">
            <span class="font-mono text-sm font-semibold text-dark-hi">reporter</span>
            <span class="text-xs text-dark-lo">Report bugs and request features for any heurema product.</span>
          </li>
        </ul>

        <div class="flex flex-col gap-2">
          <CopyButton text="skill7 install herald" />
          <CopyButton text="skill7 install anvil" />
          <CopyButton text="skill7 install reporter" />
        </div>

        <div class="callout-tip text-xs">Try in 2 minutes — no accounts, no hosted login, no API keys required.</div>
      </div>

      <div class="card flex flex-col gap-5">
        <div>
          <div class="mb-1 flex items-center gap-2">
            <span class="text-xs font-mono font-semibold uppercase tracking-widest text-cyan">Pro Pack</span>
          </div>
          <p class="text-sm leading-relaxed text-dark-lo">Risk-adaptive development, orchestration, and multi-model review.</p>
        </div>

        <ul class="flex flex-col gap-2">
          <li class="flex flex-col gap-0.5">
            <span class="font-mono text-sm font-semibold text-dark-hi">signum</span>
            <span class="text-xs text-dark-lo">Contract-first development pipeline with holdouts and proofpacks.</span>
          </li>
          <li class="flex flex-col gap-0.5">
            <span class="font-mono text-sm font-semibold text-dark-hi">arbiter</span>
            <span class="text-xs text-dark-lo">Multi-AI orchestrator for Codex CLI, Gemini CLI, and Claude Code.</span>
          </li>
        </ul>

        <div class="flex flex-col gap-2">
          <CopyButton text="skill7 install signum" />
          <CopyButton text="skill7 install arbiter" />
        </div>

        <div class="callout-info text-xs">
          Requires Codex CLI and/or Gemini CLI to be available in your PATH.
        </div>
      </div>
    </div>

    <p class="mt-8 text-center text-xs text-dark-dim">
      Questions about data usage?
      <a href="/trust" class="text-dark-lo underline underline-offset-2 transition-colors hover:text-acid">
        Trust &amp; Privacy
      </a>
    </p>
  </section>

  <section class="border-t border-dark-line py-16">
    <div class="mb-8 flex items-center gap-3">
      <h2 class="heading-section text-2xl">Categories</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {categories.map((cat) => (
        <a href={`/${cat.name}`} class="card block group">
          <h3 class="heading-section text-xl group-hover:text-acid transition-colors">{cat.displayName}</h3>
          <p class="mt-2 text-sm leading-relaxed text-dark-lo">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="border-t border-dark-line py-16">
    <div class="mb-8 flex items-center gap-3">
      <h2 class="heading-section text-2xl">All Plugins</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {allPlugins.map((plugin) => (
        <PluginCard plugin={plugin} />
      ))}
    </div>
  </section>
</Base>
