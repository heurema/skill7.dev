---
import Base from "../layouts/Base.astro";
import CopyButton from "../components/CopyButton.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<Base
  title="Getting Started"
  description="Marketplace onboarding for skill7.dev. Add the heurema emporium registry, then install any plugin from the catalog."
>

  <div class="max-w-2xl">
    <Breadcrumb items={[
      { label: "Home", href: "/" },
      { label: "Marketplace", href: "/marketplace" },
      { label: "Getting Started" },
    ]} />
    <h1 class="font-heading font-bold tracking-tight">Getting Started</h1>
    <p class="mt-3 text-lg text-dark-lo leading-relaxed">
      Add the marketplace once, then install plugins as needed.
    </p>

    <div class="callout-warn mt-8">
      <strong class="font-semibold">Prerequisite:</strong>{" "}
      Claude Code CLI must be installed.{" "}
      <a
        href="https://docs.anthropic.com/en/docs/claude-code/overview"
        class="underline hover:text-warn transition-colors"
        target="_blank"
        rel="noopener"
      >
        Install Claude Code
      </a>
    </div>

    <div class="mt-12">
      <section>
        <h2 class="heading-section text-2xl mb-4">What lives in the Marketplace?</h2>
        <p class="text-dark-lo leading-relaxed">
          Marketplace entries are installable Claude Code plugins. Hosted products like
          <a href="/sift" class="mx-1 text-acid hover:text-acid-glow transition-colors">Sift</a>
          have their own product pages and browser auth flow.
        </p>
      </section>
    </div>

    <div class="mt-10 space-y-10">
      <section>
        <div class="flex items-center gap-3 mb-4">
          <span class="step-indicator">1</span>
          <h2 class="heading-section text-2xl">Add the marketplace</h2>
        </div>
        <div class="pl-0 sm:pl-10">
          <p class="text-dark-lo leading-relaxed mb-4">
            Add the heurema emporium marketplace:
          </p>
          <CopyButton text="claude plugin marketplace add heurema/emporium" />
          <p class="mt-3 text-sm text-dark-lo">
            Run once. After that, all plugins in the catalog become installable.
          </p>
        </div>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <span class="step-indicator">2</span>
          <h2 class="heading-section text-2xl">Install a plugin</h2>
        </div>
        <div class="pl-0 sm:pl-10">
          <p class="text-dark-lo leading-relaxed mb-4">
            Browse the catalog, pick a plugin, and install it:
          </p>
          <CopyButton text="claude plugin install sigil@emporium" />
          <p class="mt-3 text-sm text-dark-lo">
            The plugin is now active in your Claude Code sessions.
          </p>
        </div>
      </section>
    </div>

    <div class="mt-12 pt-6 border-t border-dark-line">
      <div class="flex flex-col gap-3 sm:flex-row">
        <a href="/marketplace" class="btn-primary justify-center sm:w-auto">Browse Marketplace</a>
        <a href="/sift" class="btn-secondary justify-center sm:w-auto">Open Sift</a>
      </div>
    </div>
  </div>

</Base>
