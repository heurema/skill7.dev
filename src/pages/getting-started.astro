---
import Base from "../layouts/Base.astro";
import CopyButton from "../components/CopyButton.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<Base
  title="Getting Started"
  description="Install nex and start using plugins for Claude Code, Codex CLI, and Gemini CLI in three steps."
>

  <div class="max-w-2xl">
    <Breadcrumb items={[
      { label: "Home", href: "/" },
      { label: "Getting Started" },
    ]} />
    <h1 class="font-heading font-bold tracking-tight">Getting Started</h1>
    <p class="mt-3 text-lg text-dark-lo leading-relaxed">
      Install <code class="inline-code">nex</code>, then install any plugin from the registry — for all your AI CLIs at once.
    </p>

    <div class="callout-warn mt-8">
      <strong class="font-semibold">Prerequisite:</strong>{" "}
      At least one AI CLI must be installed: Claude Code, Codex CLI, or Gemini CLI.{" "}
      <a
        href="https://docs.anthropic.com/en/docs/claude-code/overview"
        class="underline hover:text-warn transition-colors"
        target="_blank"
        rel="noopener"
      >
        Claude Code
      </a>
      {" · "}
      <a
        href="https://github.com/openai/codex"
        class="underline hover:text-warn transition-colors"
        target="_blank"
        rel="noopener"
      >
        Codex CLI
      </a>
      {" · "}
      <a
        href="https://github.com/google-gemini/gemini-cli"
        class="underline hover:text-warn transition-colors"
        target="_blank"
        rel="noopener"
      >
        Gemini CLI
      </a>
    </div>

    <div class="mt-12 space-y-10">
      <section>
        <div class="flex items-center gap-3 mb-4">
          <span class="step-indicator">1</span>
          <h2 class="heading-section text-2xl">Install nex</h2>
        </div>
        <div class="pl-0 sm:pl-10">
          <div class="flex gap-1 mb-4" id="install-tabs">
            <button data-tab="curl" class="install-tab active text-xs font-mono px-3 py-1.5 rounded border transition-colors">curl</button>
            <button data-tab="cargo" class="install-tab text-xs font-mono px-3 py-1.5 rounded border transition-colors">cargo</button>
          </div>
          <div data-panel="curl" class="install-panel">
            <CopyButton text="curl -fsSL https://skill7.dev/install.sh | sh" />
          </div>
          <div data-panel="cargo" class="install-panel hidden">
            <CopyButton text="cargo install --git https://github.com/heurema/nex --locked" />
          </div>
          <p class="mt-4 text-sm text-dark-dim">
            Requires the <a href="https://rustup.rs" class="text-dark-lo underline hover:text-acid transition-colors" target="_blank" rel="noopener">Rust toolchain</a>. Or download a binary from the <a href="https://github.com/heurema/nex/releases" class="text-dark-lo underline hover:text-acid transition-colors" target="_blank" rel="noopener">releases page</a>.
          </p>
        </div>

        <script>
          const tabs = document.querySelectorAll<HTMLButtonElement>('.install-tab');
          const panels = document.querySelectorAll<HTMLElement>('.install-panel');
          tabs.forEach(tab => {
            tab.addEventListener('click', () => {
              const target = tab.dataset.tab;
              tabs.forEach(t => {
                const isActive = t.dataset.tab === target;
                t.classList.toggle('border-acid', isActive);
                t.classList.toggle('text-acid', isActive);
                t.classList.toggle('bg-acid-muted', isActive);
                t.classList.toggle('border-dark-line', !isActive);
                t.classList.toggle('text-dark-lo', !isActive);
                t.classList.toggle('active', isActive);
              });
              panels.forEach(p => {
                p.classList.toggle('hidden', p.dataset.panel !== target);
              });
            });
          });
          // Init first tab
          const first = document.querySelector<HTMLButtonElement>('.install-tab.active');
          if (first) first.click();
        </script>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <span class="step-indicator">2</span>
          <h2 class="heading-section text-2xl">Install a plugin</h2>
        </div>
        <div class="pl-0 sm:pl-10">
          <p class="text-dark-lo leading-relaxed mb-4">
            Install a plugin from the registry. <code class="inline-code">herald</code> is a good first pick — local news intelligence, no API keys required:
          </p>
          <CopyButton text="nex install herald" />
          <p class="mt-4 text-sm text-dark-lo">
            nex detects which AI CLIs you have and installs the plugin for all of them automatically.
          </p>
          <div class="mt-5 rounded border border-[#3d3530] bg-[#2a2520] px-4 py-4 font-mono text-sm leading-relaxed">
            <div><span class="text-[#00e5a0]">$</span> <span class="text-[#e8edf8]">nex install herald</span></div>
            <div class="mt-1 text-[#8b9cbf]">  Fetching registry...</div>
            <div class="text-[#00c97a]">  ✓ Detected: Claude Code</div>
            <div class="text-[#8b9cbf]">  Installing herald for Claude Code... done</div>
            <div class="mt-1 text-[#00c97a]">  herald is ready. Run /herald in Claude Code to start.</div>
          </div>
        </div>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <span class="step-indicator">3</span>
          <h2 class="heading-section text-2xl">Verify</h2>
        </div>
        <div class="pl-0 sm:pl-10">
          <p class="text-dark-lo leading-relaxed mb-4">
            Check which plugins are installed:
          </p>
          <CopyButton text="nex list" />
          <p class="mt-3 text-sm text-dark-lo">
            Use <code class="inline-code">nex check</code> to verify plugin integrity, or <code class="inline-code">nex update</code> to pull the latest versions.
          </p>
        </div>
      </section>
    </div>

    <div class="mt-12 pt-6 border-t border-dark-line">
      <div class="flex flex-col gap-3 sm:flex-row">
        <a href="/marketplace" class="btn-primary justify-center sm:w-auto">Browse registry</a>
        <a href="/docs" class="btn-secondary justify-center sm:w-auto">CLI reference</a>
      </div>
    </div>
  </div>

</Base>
