---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import CopyButton from "../components/CopyButton.astro";
---

<Base
  title="Signum — Evidence-Driven Development Pipeline"
  description="Write contracts before writing code. Multi-model audit, holdout blinding, tamper-evident proofpack. A Claude Code plugin that proves your AI-generated code was reviewed."
>
  <div class="mx-auto max-w-6xl">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Signum" }]} />

    <!-- Hero -->
    <section class="relative overflow-hidden rounded-3xl border border-dark-line bg-dark-base px-6 py-16 shadow-panel sm:px-10">
      <div
        class="absolute inset-0 pointer-events-none"
        style="background:
          radial-gradient(circle at 15% 20%, rgba(0,229,160,0.12) 0%, transparent 35%),
          radial-gradient(circle at 85% 10%, rgba(0,180,216,0.08) 0%, transparent 30%);"
      />

      <div class="relative grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-acid/40 bg-acid-muted px-3 py-1">
            <span class="h-1.5 w-1.5 rounded-full bg-acid animate-pulse"></span>
            <span class="text-xs font-mono font-medium text-acid">Claude Code plugin</span>
          </div>

          <h1 class="mt-6 font-heading text-4xl font-bold tracking-tight text-dark-hi sm:text-5xl lg:text-6xl">
            Proof of review
            <br />
            <span class="text-gradient-hero">for AI-generated code</span>
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-relaxed text-dark-lo">
            AI writes code in seconds. But &ldquo;correct&rdquo; isn&rsquo;t defined until someone writes it down.
            Signum turns every task into a contract, implements against it, audits with 3 independent models,
            and produces a tamper-evident proofpack.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#install" class="btn-primary justify-center sm:w-auto">
              Install free plugin
            </a>
            <a href="#setup-call" class="btn-secondary justify-center sm:w-auto">
              Book a setup call
            </a>
            <a href="#how-it-works" class="btn-ghost justify-center sm:w-auto">
              How it works
            </a>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="card-sm border-gradient-acid">
            <p class="text-xs font-mono uppercase tracking-widest text-acid">The problem</p>
            <p class="mt-3 text-sm leading-relaxed text-dark-lo">
              A single model reviewing its own output is a self-audit.
              Your manual review is too shallow. Bugs slip through.
              There is no proof the code was actually checked.
            </p>
          </div>

          <div class="card-sm">
            <p class="text-xs font-mono uppercase tracking-widest text-cyan">3 verdicts, zero ambiguity</p>
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-dark-lo">
              <li class="flex items-baseline gap-3"><span class="shrink-0 w-24 font-mono text-ok">AUTO_OK</span> <span>Safe to commit</span></li>
              <li class="flex items-baseline gap-3"><span class="shrink-0 w-24 font-mono text-err">AUTO_BLOCK</span> <span>Regression found</span></li>
              <li class="flex items-baseline gap-3"><span class="shrink-0 w-24 font-mono text-warn">HUMAN</span> <span>Needs your review</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Pipeline -->
    <section id="how-it-works" class="py-16">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">How it works</p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
        Four phases, one approval gate
      </h2>
      <p class="mt-4 max-w-2xl text-dark-lo">
        You approve the contract. Everything after that is autonomous.
      </p>

      <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div class="card-sm pt-8">
          <p class="text-xs font-mono font-semibold text-acid mb-2">Phase 1</p>
          <h3 class="font-heading text-lg font-semibold text-dark-hi">Contract</h3>
          <p class="mt-2 text-sm text-dark-lo">
            Task decomposed into goal, scope, acceptance criteria, and hidden holdout scenarios.
            Spec scored A&ndash;F. Grade D is a hard stop.
          </p>
          <p class="mt-3 text-xs font-mono text-acid">You approve here</p>
        </div>

        <div class="card-sm pt-8">
          <p class="text-xs font-mono font-semibold text-dark-dim mb-2">Phase 2</p>
          <h3 class="font-heading text-lg font-semibold text-dark-hi">Execute</h3>
          <p class="mt-2 text-sm text-dark-lo">
            Engineer implements against the contract. Scope gate blocks out-of-scope changes.
            Execution policy constrains allowed tools and commands.
          </p>
          <p class="mt-3 text-xs font-mono text-dark-dim">Autonomous</p>
        </div>

        <div class="card-sm pt-8">
          <p class="text-xs font-mono font-semibold text-dark-dim mb-2">Phase 3</p>
          <h3 class="font-heading text-lg font-semibold text-dark-hi">Audit</h3>
          <p class="mt-2 text-sm text-dark-lo">
            Claude, Codex, and Gemini review the diff independently.
            Holdouts run blind. Iterative fix loop &mdash; up to 20 rounds.
          </p>
          <p class="mt-3 text-xs font-mono text-dark-dim">Autonomous</p>
        </div>

        <div class="card-sm pt-8">
          <p class="text-xs font-mono font-semibold text-dark-dim mb-2">Phase 4</p>
          <h3 class="font-heading text-lg font-semibold text-dark-hi">Pack</h3>
          <p class="mt-2 text-sm text-dark-lo">
            All artifacts bundled into a tamper-evident proofpack
            with SHA-256 chain from contract to verdict.
          </p>
          <p class="mt-3 text-xs font-mono text-dark-dim">Autonomous</p>
        </div>
      </div>
    </section>

    <div class="border-t border-dark-line"></div>

    <!-- Features -->
    <section class="py-16">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">Features</p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
        Not another AI reviewer
      </h2>
      <p class="mt-4 max-w-2xl text-dark-lo">
        Signum is proof of review &mdash; a signed attestation that AI-generated code was verified.
        Compliance gate, not reviewer replacement.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-acid">Holdout blinding</p>
          <h3 class="mt-3 font-heading text-xl font-semibold text-dark-hi">
            Tests the Engineer never sees
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-lo">
            Hidden acceptance criteria are physically removed from the implementation contract.
            After coding, holdouts run as blind validation. The implementing agent cannot game them.
          </p>
        </div>

        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-acid">Multi-model audit</p>
          <h3 class="mt-3 font-heading text-xl font-semibold text-dark-hi">
            Three models, adversarial isolation
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-lo">
            Claude reviews semantics, Codex reviews security, Gemini reviews performance.
            Each sees only goal + diff. A critical finding from any model triggers AUTO_BLOCK.
          </p>
        </div>

        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-acid">Proofpack</p>
          <h3 class="mt-3 font-heading text-xl font-semibold text-dark-hi">
            Tamper-evident artifact
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-lo">
            Contract hash &rarr; approval timestamp &rarr; base commit &rarr; diff &rarr; audit results.
            Single proofpack file with per-artifact SHA-256 envelopes.
          </p>
        </div>

        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-cyan">Iterative fix loop</p>
          <h3 class="mt-3 font-heading text-xl font-semibold text-dark-hi">
            Up to 20 repair rounds
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-lo">
            When findings appear, the pipeline loops: repair &rarr; re-audit &rarr; repeat.
            Parallel repair lanes try different strategies. Best-of-N selection.
          </p>
        </div>

        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-cyan">Spec quality gate</p>
          <h3 class="mt-3 font-heading text-xl font-semibold text-dark-hi">
            Grade D = no code written
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-lo">
            Contracts scored A&ndash;F across 7 dimensions: testability, negative coverage, clarity,
            scope, completeness, boundaries, NL consistency.
          </p>
        </div>

        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-cyan">Policy scanner</p>
          <h3 class="mt-3 font-heading text-xl font-semibold text-dark-hi">
            Zero-cost security scan
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-lo">
            Deterministic scan on the diff for 12 security patterns:
            eval, XSS, SQL injection, weak crypto. CRITICAL findings trigger AUTO_BLOCK before any model runs.
          </p>
        </div>
      </div>
    </section>

    <div class="border-t border-dark-line"></div>

    <!-- Demo -->
    <section class="py-16">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">In action</p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
        One command, full pipeline
      </h2>
      <p class="mt-4 max-w-2xl text-dark-lo">
        Run <code class="inline-code">/signum</code> with a task description.
        Approve the contract. Come back to a verdict and a proofpack.
      </p>

      <div class="mt-10 flex justify-center">
        <div class="relative w-full rounded-2xl p-px shadow-glow-lg"
             style="max-width: 883px;
                    background: linear-gradient(var(--color-surface), var(--color-surface)) padding-box,
                                linear-gradient(135deg, rgba(0,229,160,0.45), rgba(0,180,216,0.3)) border-box;
                    border: 1px solid transparent;">
          <div class="overflow-hidden rounded-2xl bg-dark-bg">
            <div class="flex items-center gap-2 border-b border-dark-line px-4 py-2.5">
              <span class="h-3 w-3 rounded-full bg-err/60"></span>
              <span class="h-3 w-3 rounded-full bg-warn/60"></span>
              <span class="h-3 w-3 rounded-full bg-ok/60"></span>
              <span class="ml-2 text-xs font-mono text-dark-dim">signum pipeline</span>
            </div>
            <img
              src="/signum-demo.gif"
              alt="Signum pipeline demo: contract approval, multi-model audit, proofpack generation"
              class="block w-full"
              loading="lazy"
              width="883"
              height="406"
            />
          </div>
        </div>
      </div>
    </section>

    <div class="border-t border-dark-line"></div>

    <!-- Setup Call CTA -->
    <section id="setup-call" class="py-16">
      <div class="relative overflow-hidden rounded-2xl border border-acid/30 bg-dark-base px-6 py-12 sm:px-10">
        <div
          class="absolute inset-0 pointer-events-none"
          style="background: radial-gradient(circle at 50% 50%, rgba(0,229,160,0.06) 0%, transparent 50%);"
        />

        <div class="relative grid gap-8 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="text-xs font-mono uppercase tracking-widest text-acid">For teams and solo devs</p>
            <h2 class="mt-3 font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
              Setup call
            </h2>
            <p class="mt-4 text-dark-lo leading-relaxed">
              30 minutes. I install Signum in your project, configure risk levels, run it on one of your PRs live,
              and walk you through the proofpack. You keep the full audit trail.
            </p>
            <ul class="mt-6 space-y-3 text-sm text-dark-lo">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-acid"></span>
                <span>Signum installed and configured for your repo</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-acid"></span>
                <span>Live audit on your real PR &mdash; you see the full pipeline</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-acid"></span>
                <span>Proofpack walkthrough &mdash; what each section means, how to use in CI</span>
              </li>
            </ul>
          </div>

          <div class="card-sm text-center lg:text-left">
            <p class="font-heading text-4xl font-bold text-dark-hi">$99</p>
            <p class="mt-1 text-sm text-dark-dim">30 min &middot; 1-on-1 &middot; your codebase</p>
            <a
              href="mailto:v@skill7.dev?subject=Signum%20setup%20call&body=Hi%2C%20I%E2%80%99d%20like%20to%20book%20a%20Signum%20setup%20call.%0A%0AProject%3A%20%0ATeam%20size%3A%20%0AMain%20pain%20point%3A%20"
              class="btn-primary justify-center w-full mt-6"
            >
              Book now
            </a>
            <p class="mt-4 text-xs text-dark-dim">
              Or reply in the
              <a href="https://github.com/heurema/signum/discussions" class="text-acid hover:underline" target="_blank" rel="noopener">GitHub Discussion</a>
              with a PR link &mdash; I&rsquo;ll audit it for free.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="border-t border-dark-line"></div>

    <!-- How it runs -->
    <section class="py-16">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">Under the hood</p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
        Uses your existing AI subscriptions
      </h2>
      <p class="mt-4 max-w-2xl text-dark-lo">
        Signum is a free, open-source Claude Code plugin. It runs on your own API subscriptions &mdash;
        Anthropic (required), plus OpenAI and Google for multi-model audit (optional).
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        <div class="card-sm text-center">
          <p class="font-heading text-2xl font-bold text-dark-hi">Anthropic</p>
          <p class="mt-2 text-sm text-dark-lo">Claude Code subscription. Required. Powers the pipeline core.</p>
        </div>
        <div class="card-sm text-center">
          <p class="font-heading text-2xl font-bold text-dark-hi">OpenAI</p>
          <p class="mt-2 text-sm text-dark-lo">Codex CLI. Optional. Adds security-focused review.</p>
        </div>
        <div class="card-sm text-center">
          <p class="font-heading text-2xl font-bold text-dark-hi">Google</p>
          <p class="mt-2 text-sm text-dark-lo">Gemini CLI. Optional. Adds performance-focused review.</p>
        </div>
      </div>

      <p class="mt-6 text-sm text-dark-dim text-center">
        External providers receive only the goal and diff. Never the full codebase. No telemetry.
      </p>
    </section>

    <div class="border-t border-dark-line"></div>

    <!-- Install -->
    <section id="install" class="py-16">
      <p class="text-xs font-mono uppercase tracking-widest text-acid">Get started</p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
        Install in 30 seconds
      </h2>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <div>
          <p class="text-sm font-medium text-dark-hi mb-3">Via nex (recommended)</p>
          <CopyButton text="nex install signum" />

          <p class="text-sm font-medium text-dark-hi mt-6 mb-3">Via Claude Code CLI</p>
          <CopyButton text="claude plugin install signum@emporium" />

          <p class="text-sm font-medium text-dark-hi mt-6 mb-3">Then run</p>
          <CopyButton text='/signum "Add a health check endpoint"' />
        </div>

        <div class="card-sm">
          <p class="text-xs font-mono uppercase tracking-widest text-cyan">Requirements</p>
          <ul class="mt-4 space-y-2 text-sm text-dark-lo">
            <li><span class="font-mono text-dark-hi">claude-code</span> v2.1+</li>
            <li><span class="font-mono text-dark-hi">git</span>, <span class="font-mono text-dark-hi">jq</span>, <span class="font-mono text-dark-hi">python3</span></li>
            <li><span class="font-mono text-dark-hi">codex</span> + <span class="font-mono text-dark-hi">gemini</span> CLI <span class="text-dark-dim">(optional)</span></li>
          </ul>

          <p class="text-xs font-mono uppercase tracking-widest text-cyan mt-6">Privacy</p>
          <p class="mt-2 text-sm text-dark-lo">
            External providers receive only goal + diff. Never the full codebase.
            No telemetry. All artifacts stay in <code class="inline-code">.signum/</code>.
          </p>
        </div>
      </div>
    </section>

    <div class="border-t border-dark-line"></div>

    <!-- Email capture + final CTA -->
    <section class="py-16">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-heading text-3xl font-bold text-dark-hi sm:text-4xl">
          Ship AI code with <span class="text-gradient-hero">proof</span>
        </h2>
        <p class="mt-4 text-dark-lo">
          Signum is shipping new capabilities: CI merge gates, audit dashboards, team compliance reports.
          Get notified when they land.
        </p>

        <form
          action="https://buttondown.com/api/emails/embed-subscribe/signum"
          method="post"
          target="popupwindow"
          class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center"
        >
          <input
            type="email"
            name="email"
            placeholder="you@company.com"
            required
            class="input w-full sm:w-72"
          />
          <button type="submit" class="btn-primary justify-center shrink-0">
            Get updates
          </button>
        </form>

        <p class="mt-3 text-xs text-dark-dim">No spam. Unsubscribe anytime.</p>

        <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a
            href="https://github.com/heurema/signum"
            class="btn-secondary justify-center"
            target="_blank"
            rel="noopener"
          >
            Star on GitHub
          </a>
          <a
            href="https://github.com/heurema/signum/discussions"
            class="btn-ghost justify-center"
            target="_blank"
            rel="noopener"
          >
            Join the discussion
          </a>
        </div>

        <p class="mt-6 text-sm text-dark-dim">
          MIT licensed &middot;
          <a href="https://github.com/heurema/signum" class="text-acid hover:underline" target="_blank" rel="noopener">heurema/signum</a>
        </p>
      </div>
    </section>
  </div>
</Base>
